package web

import (
	"strings"

	"github.com/no42-org/blittermib/internal/correlate"
	"github.com/no42-org/blittermib/internal/model"
)

// SymbolView aggregates everything the symbol detail page needs:
// the symbol itself, its in-context placement (where it sits in the
// SMI tree), the columns of a table when applicable, inbound
// references for the Used-by panel, and the SMI source slice for
// the Show-full-SMI-source disclosure.
//
// `NotifyObjects` is the SMIv2 NOTIFICATION-TYPE OBJECTS clause —
// the variable-bindings a trap receiver should expect alongside the
// notification. Only populated for `KindNotificationType` /
// `KindTrapType` symbols; the workspace right pane renders each
// entry as a clickable link to that object's workspace page so a
// reader can jump straight from "what does linkDown carry?" to the
// detail of `ifAdminStatus`.
//
// `TrapIndex` describes how the trap-simulator modal should prompt
// for the row identity when composing the OIDs for those varbinds:
// `indexed` walks the per-column descriptors to render type-
// specific inputs (numeric for INTEGER, dotted-quad for IpAddress,
// etc.); `scalar-only` for notifications whose objects are all
// scalars; and `raw-suffix` is the v1.0 fallback for what the
// classifier doesn't yet handle (multi-column composites, OCTET
// STRING / OID / BITS indexes, multi-parent notifications) —
// those degrade to a free-form text input where the user types
// the dotted suffix themselves.
type SymbolView struct {
	Symbol        *model.Symbol
	Context       *SymbolContext
	Columns       []TableColumn
	UsedBy        []model.Reference
	NotifyObjects []NotifyVarbind
	TrapIndex     TrapIndexStrategy
	SourceText    string // raw SMI lines from the module's source file
	SourcePath    string // module.source_path; empty if no source available
	// Relationship is the inferred raise/clear/orphan classification for
	// a NOTIFICATION-TYPE/TRAP-TYPE symbol; nil for anything else or when
	// inference produced no record.
	Relationship *correlate.Relationship
}

// SymbolDetail renders the canonical reference page for a symbol
// at /s/{module}::{name}. The breadcrumb header is page-specific;
// the rest delegates to symbolDetailBody, which is also embedded by
// the workspace right pane so the two surfaces never drift.
templ SymbolDetail(view *SymbolView) {
	@Base(view.Symbol.QualifiedName() + " · blittermib") {
		<nav class="breadcrumb">
			<a href={ moduleURL(view.Symbol.ModuleName) }>{ view.Symbol.ModuleName }</a>
			<span class="sep">›</span>
			{ view.Symbol.Name }
		</nav>
		@symbolDetailBody(view)
	}
}

// symbolDetailBody renders the symbol's name, OID, type-line, enum
// values, in-context block, description, columns (when applicable),
// used-by, and source disclosure. Reused by both the canonical
// /s/... page and the workspace right pane.
templ symbolDetailBody(view *SymbolView) {
	<h1 class="symbol-name">{ view.Symbol.Name }</h1>
	<p class="summary">{ summarizeSymbol(view.Symbol) }</p>
	<div class="oid-row">
		<span class="oid">
			@templ.Raw(FormatOIDHTML(view.Symbol.OID))
		</span>
	</div>
	<div class="type-line">
		if view.Symbol.Syntax != "" {
			<span class="syntax">{ view.Symbol.Syntax }</span>
		}
		if view.Symbol.Access != "" {
			<span class="sep">·</span>
			{ string(view.Symbol.Access) }
		}
		if view.Symbol.Status != "" {
			<span class="sep">·</span>
			{ string(view.Symbol.Status) }
		}
		if view.Symbol.Units != "" {
			<span class="sep">·</span>
			units: { view.Symbol.Units }
		}
	</div>
	if view.Relationship != nil {
		<section class="section rel-section">
			<h2 class="section-label">Alarm semantics</h2>
			<p class="rel-line">
				@notificationBadge(*view.Relationship)
				if view.Relationship.Class == correlate.ClassClear && len(view.Relationship.Clears) > 0 {
					<span class="rel-clears">resolves <code>{ strings.Join(view.Relationship.Clears, ", ") }</code></span>
				}
				<span class="rel-conf">confidence: { string(view.Relationship.Confidence) }</span>
			</p>
			<details class="rel-evidence">
				<summary>Why was this inferred?</summary>
				<p class="prose">{ view.Relationship.Evidence.String() }</p>
			</details>
		</section>
	}
	if len(view.Symbol.EnumValues) > 0 {
		<section class="section">
			<h2 class="section-label">Values</h2>
			<ul class="enum-list">
				for _, ev := range view.Symbol.EnumValues {
					<li><code>{ ev.Name }({ fmtInt64(ev.Number) })</code></li>
				}
			</ul>
		</section>
	}
	if view.Context != nil {
		@inContext(view.Context)
	}
	if view.Symbol.Description != "" {
		<section class="section">
			<h2 class="section-label">Description</h2>
			<div class="prose">
				<p>{ view.Symbol.Description }</p>
			</div>
		</section>
	}
	if len(view.Columns) > 0 {
		<section class="section">
			<h2 class="section-label">Columns</h2>
			<table class="toc-table">
				<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Column</th>
						<th scope="col">Syntax</th>
						<th scope="col">Access</th>
						<th scope="col">Status</th>
					</tr>
				</thead>
				<tbody>
					for _, c := range view.Columns {
						<tr>
							<td class="col-num">{ c.Position }</td>
							<td class="col-name">
								<a href={ symbolURL(c.Module, c.Name) }>{ c.Name }</a>
								if c.IsIndex {
									<span class="key">index</span>
								}
							</td>
							<td class="col-syntax">{ c.Syntax }</td>
							<td class="col-access">{ c.Access }</td>
							<td class="col-status">{ c.Status }</td>
						</tr>
					}
				</tbody>
			</table>
		</section>
	}
	if len(view.UsedBy) > 0 {
		<section class="section">
			<h2 class="section-label">Used by</h2>
			<table class="refs">
				<tbody>
					for _, ref := range view.UsedBy {
						<tr>
							<td><a href={ symbolURL(ref.SourceModule, ref.SourceName) }><code>{ ref.SourceName }</code></a></td>
							<td class="kind">{ string(ref.Kind) }</td>
							<td class="module">{ ref.SourceModule }</td>
						</tr>
					}
				</tbody>
			</table>
		</section>
	}
	if view.SourceText != "" {
		<details class="disclosure">
			<summary>Show full SMI source</summary>
			<pre class="disclosure-body">{ view.SourceText }</pre>
			if view.SourcePath != "" {
				<p class="see-more">
					<a href={ moduleSourceURL(view.Symbol.ModuleName) }>View entire MIB source →</a>
				</p>
			}
		</details>
	}
}

// inContext is a small fragment so the SymbolDetail body stays readable.
templ inContext(info *SymbolContext) {
	<section class="section">
		<h2 class="section-label">In context</h2>
		<dl class="kv-grid">
			if info.ColumnNumber != "" && info.ParentTable != nil {
				<dt>Column</dt>
				<dd>{ info.ColumnNumber } of <a href={ symbolURL(info.ParentTable.Module, info.ParentTable.Name) }>{ info.ParentTable.Module }::{ info.ParentTable.Name }</a></dd>
			} else if info.ParentTable != nil {
				<dt>Part of</dt>
				<dd><a href={ symbolURL(info.ParentTable.Module, info.ParentTable.Name) }>{ info.ParentTable.Module }::{ info.ParentTable.Name }</a></dd>
			}
			if len(info.IndexedBy) > 0 {
				<dt>Indexed by</dt>
				<dd>
					for i, idx := range info.IndexedBy {
						if i > 0 {
							{ ", " }
						}
						<a href={ symbolURL(idx.Module, idx.Name) }><code>{ idx.Name }</code></a>
					}
				</dd>
			}
			if info.Augments != nil {
				<dt>Augments</dt>
				<dd><a href={ symbolURL(info.Augments.Module, info.Augments.Name) }>{ info.Augments.Module }::{ info.Augments.Name }</a></dd>
			}
		</dl>
	</section>
}

// notificationBadge renders the inferred raise/clear/orphan badge.
// Classification is conveyed by icon + text + colour (never colour
// alone — WCAG 1.4.1), with the confidence in the accessible name.
templ notificationBadge(rel correlate.Relationship) {
	switch rel.Class {
		case correlate.ClassRaise:
			<span class="rel-pill rel-raise" aria-label={ "inferred: raises a problem, " + string(rel.Confidence) + " confidence" }>▲ raise</span>
		case correlate.ClassClear:
			<span class="rel-pill rel-clear" aria-label={ "inferred: clears a problem, " + string(rel.Confidence) + " confidence" }>↺ clears</span>
		case correlate.ClassOrphan:
			<span class="rel-pill rel-orphan" aria-label={ "inferred: no resolution, " + string(rel.Confidence) + " confidence" }>⊘ orphan</span>
	}
}

// notificationBadgeIcon is the compact, icon-only variant used in dense
// list rows. Meaning is carried by the distinct glyph (not colour alone —
// WCAG 1.4.1) with the full classification + confidence in the accessible
// name and a hover title; the full labelled badge lives in the detail pane.
//
// The stable `rel-badge-{name}` id lets a same-scope partial nav keep this
// badge in sync via a targeted out-of-band swap (oob=true) — the list pane
// isn't re-rendered on same-scope selection, so without this the badge
// could lag the detail pane after a runtime re-classification.
templ notificationBadgeIcon(rel correlate.Relationship, name string, oob bool) {
	switch rel.Class {
		case correlate.ClassRaise:
			<span id={ "rel-badge-" + name } if oob { hx-swap-oob="outerHTML" } class="rel-pill rel-icon rel-raise" title="raises a problem" aria-label={ "inferred: raises a problem, " + string(rel.Confidence) + " confidence" }>▲</span>
		case correlate.ClassClear:
			<span id={ "rel-badge-" + name } if oob { hx-swap-oob="outerHTML" } class="rel-pill rel-icon rel-clear" title="clears a problem" aria-label={ "inferred: clears a problem, " + string(rel.Confidence) + " confidence" }>↺</span>
		case correlate.ClassOrphan:
			<span id={ "rel-badge-" + name } if oob { hx-swap-oob="outerHTML" } class="rel-pill rel-icon rel-orphan" title="no resolution" aria-label={ "inferred: no resolution, " + string(rel.Confidence) + " confidence" }>⊘</span>
	}
}
