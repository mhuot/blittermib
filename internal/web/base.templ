package web

// Base is the shared HTML shell: topbar with brand mark, wordmark,
// tagline, privacy notice and theme toggle; content area; footer
// mirroring blitsbom. The page-specific content is supplied via
// templ children.
//
// The inline theme-init <script> in <head> applies the saved theme
// before paint to avoid a flash of the wrong palette. It mirrors
// what blitsbom does (see CLAUDE.md sister-product alignment).
templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			// htmx history is disabled. Without this, every hx-push-url
			// navigation cloned and serialized the entire <body> into
			// localStorage — on large modules (FspR7-MIB renders ~10 MB
			// of HTML) the write always exceeded the quota, firing
			// htmx:historyCacheError in a retry loop that janked every
			// click. Two pieces, both needed: hx-history="false" on
			// <body> is what actually skips the snapshot — in htmx 2.0.4
			// saveToHistoryCache serializes the DOM *before* checking
			// historyCacheSize, so the cache-size knob alone doesn't
			// stop the clone. This meta then clears any stale cache from
			// localStorage and makes back/forward a plain full-page load
			// instead of an ajax restore.
			<meta name="htmx-config" content={ `{"historyCacheSize": 0, "refreshOnHistoryMiss": true}` }/>
			<title>{ title }</title>
			<script>
				// Pre-paint theme application — keep this tight and inline.
				try {
					var t = localStorage.getItem('blittermib-theme');
					if (t === 'light' || t === 'dark') {
						document.documentElement.dataset.theme = t;
					}
				} catch (e) {}
			</script>
			<link rel="stylesheet" href={ assetURL("styles.css") }/>
			<script src={ string(assetURL("htmx.min.js")) } defer></script>
			<script src={ string(assetURL("theme.js")) } defer></script>
			<script src={ string(assetURL("palette.js")) } defer></script>
			<script src={ string(assetURL("glossary.js")) } defer></script>
			<script src={ string(assetURL("tree.js")) } defer></script>
			<script src={ string(assetURL("workspace.js")) } defer></script>
			if walkEnabled {
				<script src={ string(assetURL("walk-overlay.js")) } defer></script>
				<script src={ string(assetURL("walk-modal.js")) } defer></script>
			}
			<script src={ string(assetURL("picker.js")) } defer></script>
			<script src={ string(assetURL("trap-simulator.js")) } defer></script>
			<script src={ string(assetURL("upload.js")) } defer></script>
			<script src={ string(assetURL("alpine.min.js")) } defer></script>
		</head>
		// hx-history="false" skips the history snapshot entirely —
		// see the htmx-config comment in <head>.
		<body hx-history="false">
			// Skip link: first focusable element so keyboard and
			// screen-reader users can jump past the repeated topbar
			// straight to the page content (WCAG 2.4.1 Bypass Blocks).
			// Visually hidden until focused — see .skip-link in styles.css.
			<a class="skip-link" href="#main">Skip to main content</a>
			// Shared icon sprite. The clipboard glyph used to be inlined
			// into every copy button — at two buttons per list row that
			// alone was ~9 MB of repeated SVG on a 7,000-symbol module.
			// Each button now references this single <symbol> via
			// <use href="#icon-copy">; the stroke styling lives here so
			// per-use markup stays minimal (currentColor still resolves
			// at the use site, so hover/copied tints keep working).
			<svg xmlns="http://www.w3.org/2000/svg" style="display:none" aria-hidden="true">
				<symbol id="icon-copy" viewBox="0 0 24 24"
					fill="none" stroke="currentColor" stroke-width="2"
					stroke-linecap="round" stroke-linejoin="round">
					<rect x="9" y="2" width="6" height="4" rx="1"></rect>
					<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
				</symbol>
			</svg>
			<header class="topbar">
				<a href="/" class="brand">
					<span class="brand-mark" aria-hidden="true">
						<span class="bar bar-1"></span>
						<span class="bar bar-2"></span>
						<span class="bar bar-3"></span>
					</span>
					<span class="brand-text">blittermib<span class="brand-dot">.</span></span>
				</a>
				<span class="brand-tagline">Pixelperfect MIB browser</span>
				<div class="topbar-spacer"></div>
				<div class="topbar-end">
					<span class="privacy-notice">Self-hosted — your MIBs never leave your server.</span>
					if walkEnabled && !isWalkPage(ctx) {
						<a href="/walk" class="walk-decode-toggle" data-walk-modal-open aria-haspopup="dialog" aria-expanded="false" aria-label="Decode SNMP Walk (⌘⇧K)" title="Decode SNMP Walk">⌘⇧K</a>
					}
					<button class="search-toggle" type="button" data-palette-toggle title="Search" aria-label="Search (⌘K)">⌘K</button>
					<button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">
						<span class="moon" aria-hidden="true">☾</span>
						<span class="sun" aria-hidden="true">☀</span>
					</button>
				</div>
			</header>
			// tabindex="-1" makes the bypass target programmatically
			// focusable so activating the skip link actually moves focus
			// here, not just the scroll position (WCAG 2.4.1).
			<main class="page" id="main" tabindex="-1">
				<div class="content-inner">
					{ children... }
				</div>
			</main>
			<footer class="footer">
				<span>
					<a href="https://github.com/no42-org/blittermib" target="_blank" rel="noopener noreferrer" title={ "blittermib " + version }>blittermib</a> · runs entirely on your server
				</span>
				<span>
					Made with AI and ❤️ for Open Source in Europe ·
					<a href="https://blog.no42.org/page/about/" target="_blank" rel="noopener noreferrer">About Me</a> ·
					<a href="/imprint">Imprint</a> ·
					<a href="/privacy">Privacy</a>
				</span>
			</footer>
			if walkEnabled && !isWalkPage(ctx) {
				<div class="walk-modal" data-walk-modal data-state="hidden" role="dialog" aria-label="Decode SNMP walk">
					<div class="walk-modal-card">
						<header class="walk-modal-head">
							<h2>Decode an SNMP walk</h2>
							<button type="button" class="walk-modal-close" data-walk-modal-close aria-label="Close">✕</button>
						</header>
						@walkIntakeForm()
					</div>
				</div>
			}
		</body>
	</html>
}
