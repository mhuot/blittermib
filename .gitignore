# MIB-ingest drop folder — contributors drop files in mibs/import/
# and run `make ingest` to have them classified into the corpus.
# Successfully-classified files are moved out; .gitkeep keeps the
# directory present in clones.
/mibs/import/*
!/mibs/import/.gitkeep

